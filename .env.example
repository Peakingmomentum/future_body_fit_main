# Copy to .env.local for local dev. Set the real values in the Vercel
# dashboard (Project Settings -> Environment Variables) for Preview + Production.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR-ANON-KEY
VITE_SUPABASE_PROJECT_ID=YOUR-PROJECT-ID

# Optional: bake an org slug into a native (Capacitor) build for white-label apps.
# Web deploys resolve the slug from subdomain instead, so leave this unset on Vercel.
# VITE_ORG_SLUG=daniel
